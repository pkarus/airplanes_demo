# PyRel runtime cache - exclude per-file rather than the whole dir, so the
# figure-generation script and the PNGs embedded in RUNNING.html stay in.
build/cache/
build/spans.jsonl
build/debug.jsonl
build/metadata.json
# PyRel writes the same runtime cache inside this module dir when modules are
# imported from the project root.
rai_code/manual/build/

# Notebook output
.ipynb_checkpoints/
*.executed.ipynb

# Claude harness
.claude/settings.local.json
.claude/scheduled_tasks.lock
